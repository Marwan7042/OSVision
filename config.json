{
    "paths": {
        "scan_dir": "./coral_scan1"
    },
    "hardware": {
        "calibration_mode": "custom",
        "target_fps": 10,
        "imu_rate_hz": 200,
        "use_ir_projector": true,
        "ir_dot_brightness_ma": 800,
        "lock_exposure": true,
        "exposure_time_us": 15000,
        "iso_sensitivity": 800,
        "decimate_factor": 1,
        "enable_intel_igpu": true
    },
    "keyframe_gating": {
        "min_frame_gap": 2,
        "max_frame_gap": 15,
        "min_depth_valid_ratio": 0.25,
        "max_blur_pixels": 5.0
    },
    "information_gating": {
        "min_information_score": 0.45,
        "weight_depth": 0.4,
        "weight_blur": 0.25,
        "weight_coverage": 0.2,
        "weight_parallax": 0.15
    },
    "runtime_budgets": {
        "visual_p95_ms": 22.0,
        "disk_p95_ms": 14.0,
        "main_loop_p95_ms": 35.0,
        "report_interval_sec": 8.0,
        "queue_pressure_raise": 0.7,
        "queue_pressure_recover": 0.35
    },
    "recovery_modes": {
        "vision_weak_min_frame_gap": 4,
        "imu_only_min_frame_gap": 8,
        "imu_only_hold_sec": 6.0,
        "disk_pressure_min_frame_gap": 10,
        "disk_pressure_save_stride": 2,
        "disk_pressure_queue_fill": 0.7,
        "vision_weak_info_bonus": 0.08
    },
    "time_sync": {
        "warn_abs_offset_s": 0.03,
        "warn_drift_s_per_s": 0.004,
        "offset_ewma_alpha": 0.08
    },
    "color_restore": {
        "enabled": true,
        "r_max_gain": 3.0,
        "g_max_gain": 1.2,
        "apply_to_hud": true,
        "apply_to_recording": true
    },
    "quality_control": {
        "ideal_depth_ratio": 0.40,
        "severe_blur_px": 10.0,
        "score_good_threshold": 0.75,
        "score_weak_threshold": 0.40
    },
    "ekf_tuning": {
        "static_variance_threshold": 0.01,
        "static_variance_window": 100,
        "min_gravity_samples": 150,
        "min_feature_update": 12,
        "depth_patch_radius": 2,
        "depth_min_mm": 300.0,
        "depth_max_mm": 5000.0,
        "imu_vibration_multiplier": 15.0
    },
    "reconstruction": {
        "depth_quantile_pruning": 0.95,
        "voxel_tracking_m": 0.02,
        "voxel_loop_m": 0.04,
        "voxel_tsdf_m": 0.005,
        "loop_closure_interval": 10,
        "min_loop_frame_distance": 50,
        "allow_multi_loops": false,
        "loop_top_k": 3,
        "z_regularize": true,
        "min_cloud_points": 200
    },
    "loop_closure_quality": {
        "max_translation_residual_m": 1.2,
        "max_rotation_residual_deg": 35.0,
        "switchable_min_weight": 0.2,
        "min_fgr_fitness": 0.08
    },
    "tsdf_quality": {
        "min_depth_valid_ratio": 0.12,
        "dynamic_depth_truncation": true,
        "dynamic_trunc_ewma_alpha": 0.15,
        "max_tracking_rmse_skip": 0.18
    }
}
